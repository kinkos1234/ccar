"use client";
import { useEffect, useState, useRef, useMemo } from "react";
import { getCurrentUser } from "@/utils/jwt";
import { User as RoleUser } from "@/utils/role";
import { apiFetch } from "@/utils/api";
import { Doughnut, Bar, Line } from 'react-chartjs-2';
import { Chart as ChartJS, ArcElement, Tooltip, Legend, BarElement, CategoryScale, LinearScale, PointElement, LineElement, Title } from 'chart.js';
ChartJS.register(ArcElement, Tooltip, Legend, BarElement, CategoryScale, LinearScale, PointElement, LineElement, Title);

function StrategyModal({ open, onClose, data, loading, error, onCopy }: any) {
  const modalRef = useRef<HTMLDivElement>(null);
  if (!open) return null;
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/60" onClick={onClose}>
      <div
        ref={modalRef}
        className="bg-[#23242B] rounded-lg shadow-lg p-6 w-full max-w-lg relative"
        onClick={e => e.stopPropagation()}
      >
        <button className="absolute top-2 right-2 text-gray-400 hover:text-white" onClick={onClose}>Г—</button>
        <h3 className="text-lg font-bold mb-2">м „лһө м ңм–ё/мқҙмҠҲ мҡ”м•Ҫ/к·јкұ°</h3>
        {loading ? (
          <div className="text-center py-8">лЎңл”© мӨ‘...</div>
        ) : error ? (
          <div className="text-red-500 py-8">{error}</div>
        ) : data ? (
          <div className="space-y-3">
            <div className="text-sm text-gray-400">кі к°қмӮ¬: {data.customer}</div>
            <div className="text-sm">мқҙмҠҲ мҡ”м•Ҫ: мҙқ {data.summary?.totalEvents || 0}кұҙ, нҸүк·  Sentiment {data.summary?.avgSentiment || 0}, Score н•©кі„ {data.summary?.scoreSum || 0}</div>
            <div className="text-sm">Top мқҙмҠҲ: {data.topIssues?.map((i: any) => `${i.title}(${i.plan}, ${i.score})`).join(", ") || '-'}</div>
            <div className="text-sm">к·јкұ°(л°ҳліө): {data.evidence?.repeated?.join(", ") || '-'}</div>
            <div className="text-sm">к·јкұ°(мһҘкё°): {data.evidence?.longUnresolved?.join(", ") || '-'}</div>
            <div className="text-sm">к·јкұ°(нҠёл Ңл“ң): {data.evidence?.trend?.join(", ") || '-'}</div>
            <div className="text-sm whitespace-pre-line bg-[#181A20] rounded p-2">м „лһө м ңм–ё: {data.aiRecommendation || '-'}</div>
            <div className="text-xs text-gray-500">мөңмў… м—…лҚ°мқҙнҠё: {data.updatedAt}</div>
            <div className="flex gap-2 mt-2">
              <button className="px-3 py-1 bg-blue-600 rounded text-white text-xs" onClick={() => onCopy(data.aiRecommendation)}>м ңм•Ҳ лӮҙмҡ© ліөмӮ¬</button>
              <button className="px-3 py-1 bg-gray-600 rounded text-white text-xs" onClick={onClose}>лӢ«кё°</button>
            </div>
          </div>
        ) : null}
      </div>
    </div>
  );
}

// лӢӨмӨ‘ м„ нғқ л“ңлЎӯлӢӨмҡҙ м»ҙнҸ¬л„ҢнҠё
function MultiSelectDropdown({ 
  label, 
  options, 
  selectedValues, 
  onSelectionChange, 
  placeholder = "м „мІҙ"
}: {
  label: string;
  options: string[];
  selectedValues: string[];
  onSelectionChange: (values: string[]) => void;
  placeholder?: string;
}) {
  const [isOpen, setIsOpen] = useState(false);
  const dropdownRef = useRef<HTMLDivElement>(null);

  // мҷёл¶Җ нҒҙлҰӯ мӢң л“ңлЎӯлӢӨмҡҙ лӢ«кё°
  useEffect(() => {
    function handleClickOutside(event: MouseEvent) {
      if (dropdownRef.current && !dropdownRef.current.contains(event.target as Node)) {
        setIsOpen(false);
      }
    }
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  const handleOptionClick = (option: string) => {
    if (selectedValues.includes(option)) {
      // мқҙлҜё м„ нғқлҗң н•ӯлӘ©мқҙл©ҙ м ңкұ°
      onSelectionChange(selectedValues.filter(v => v !== option));
    } else {
      // м„ нғқлҗҳм§Җ м•ҠмқҖ н•ӯлӘ©мқҙл©ҙ м¶”к°Җ
      onSelectionChange([...selectedValues, option]);
    }
  };

  const displayText = selectedValues.length === 0 
    ? placeholder 
    : selectedValues.length === 1 
      ? selectedValues[0]
      : `${selectedValues[0]} мҷё ${selectedValues.length - 1}к°ң`;

  return (
    <div className="flex flex-col items-start w-full" ref={dropdownRef}>
      <span className="text-xs text-gray-400 mb-0.5">{label}</span>
      <div className="relative w-full">
        <button
          type="button"
          className="bg-[#181A20] border border-[#333] rounded h-10 px-3 text-sm w-full text-left flex items-center justify-between"
          onClick={() => setIsOpen(!isOpen)}
        >
          <span className="truncate">{displayText}</span>
          <svg
            className={`w-4 h-4 transition-transform ${isOpen ? 'rotate-180' : ''}`}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        {isOpen && (
          <div className="absolute top-full left-0 right-0 mt-1 bg-[#181A20] border border-[#333] rounded max-h-48 overflow-y-auto z-50">
            {options.map(option => (
              <div
                key={option}
                className={`px-3 py-2 text-sm cursor-pointer hover:bg-[#23242B] flex items-center ${
                  selectedValues.includes(option) ? 'bg-[#23242B] text-blue-400' : 'text-white'
                }`}
                onClick={() => handleOptionClick(option)}
              >
                <div className={`w-3 h-3 mr-2 border rounded-full flex items-center justify-center flex-shrink-0 ${
                  selectedValues.includes(option) ? 'bg-blue-600 border-blue-600' : 'border-gray-400'
                }`}>
                </div>
                {option}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

// лӢЁмқј м„ нғқ л“ңлЎӯлӢӨмҡҙ м»ҙнҸ¬л„ҢнҠё (нҶ кёҖ кё°лҠҘ нҸ¬н•Ё)
function SingleSelectDropdown({ 
  label, 
  options, 
  selectedValue, 
  onSelectionChange, 
  placeholder = "м „мІҙ"
}: {
  label: string;
  options: string[];
  selectedValue: string;
  onSelectionChange: (value: string) => void;
  placeholder?: string;
}) {
  const [isOpen, setIsOpen] = useState(false);
  const dropdownRef = useRef<HTMLDivElement>(null);

  // мҷёл¶Җ нҒҙлҰӯ мӢң л“ңлЎӯлӢӨмҡҙ лӢ«кё°
  useEffect(() => {
    function handleClickOutside(event: MouseEvent) {
      if (dropdownRef.current && !dropdownRef.current.contains(event.target as Node)) {
        setIsOpen(false);
      }
    }
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  const handleOptionClick = (option: string) => {
    if (selectedValue === option) {
      // мқҙлҜё м„ нғқлҗң н•ӯлӘ©мқҙл©ҙ "м „мІҙ"лЎң л°ҳнҷҳ
      onSelectionChange(placeholder);
    } else {
      // м„ нғқлҗҳм§Җ м•ҠмқҖ н•ӯлӘ©мқҙл©ҙ н•ҙлӢ№ к°’ м„ нғқ
      onSelectionChange(option);
    }
    setIsOpen(false);
  };

  const displayText = selectedValue === placeholder ? placeholder : selectedValue;

  return (
    <div className="flex flex-col items-start w-full" ref={dropdownRef}>
      <span className="text-xs text-gray-400 mb-0.5">{label}</span>
      <div className="relative w-full">
        <button
          type="button"
          className="bg-[#181A20] border border-[#333] rounded h-10 px-3 text-sm w-full text-left flex items-center justify-between"
          onClick={() => setIsOpen(!isOpen)}
        >
          <span className="truncate">{displayText}</span>
          <svg
            className={`w-4 h-4 transition-transform ${isOpen ? 'rotate-180' : ''}`}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        {isOpen && (
          <div className="absolute top-full left-0 right-0 mt-1 bg-[#181A20] border border-[#333] rounded max-h-48 overflow-y-auto z-50">
            {options.length === 0 ? (
              <div className="px-3 py-2 text-sm text-gray-400">
                лҚ°мқҙн„°к°Җ м—ҶмҠөлӢҲлӢӨ
              </div>
            ) : (
              options.map(option => (
                <div
                  key={option}
                  className={`px-3 py-2 text-sm cursor-pointer hover:bg-[#23242B] flex items-center ${
                    selectedValue === option ? 'bg-[#23242B] text-blue-400' : 'text-white'
                  }`}
                  onClick={() => handleOptionClick(option)}
                >
                  <div className={`w-3 h-3 mr-2 border rounded-full flex items-center justify-center flex-shrink-0 ${
                    selectedValue === option ? 'bg-blue-600 border-blue-600' : 'border-gray-400'
                  }`}>
                  </div>
                  {option}
                </div>
              ))
            )}
          </div>
        )}
      </div>
    </div>
  );
}

// л№Ҳ лҢҖмӢңліҙл“ң лҚ°мқҙн„° кө¬мЎ°
const getEmptyDashboardData = () => ({
  kpi: { total: 0, inProgress: 0, delayed: 0, closed: 0, dueSoon: 0 },
  corporations: [],
  customers: [],
  customerContacts: [],
  managers: [],
  carList: [],
  worstScore: [],
  worstDelay: []
});

export default function DashboardPage() {
  // мғҒнғң кҙҖлҰ¬
  const [user, setUser] = useState<RoleUser | null>(null);
  const [data, setData] = useState<any>(getEmptyDashboardData());
  const [weeklyReport, setWeeklyReport] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [customerGroups, setCustomerGroups] = useState<string[]>([]);
  const [departments, setDepartments] = useState<string[]>([]);
  const [statuses, setStatuses] = useState<string[]>([]);
  
  // н•„н„° мғҒнғң
  const [filters, setFilters] = useState({
    corp: 'м „мІҙ',
    customerGroups: [] as string[], // ліөмҲҳ м„ нғқмңјлЎң ліҖкІҪ
    dept: 'м „мІҙ',
    status: 'м „мІҙ',
    startMonth: '',
    endMonth: '',
    manager: ''
  });
  const [filteredFilters, setFilteredFilters] = useState(filters);

  // м°ЁнҠё/лӘЁлӢ¬ мғҒнғң
  const [chartTab, setChartTab] = useState<'score'|'sentiment'>('score');
  const [groupTab, setGroupTab] = useState<'company'|'customer'|'manager'>('company');
  const [modalOpen, setModalOpen] = useState(false);
  const [modalData, setModalData] = useState<any>(null);
  const [modalLoading, setModalLoading] = useState(false);
  const [modalError, setModalError] = useState<string | null>(null);
  const [toast, setToast] = useState<string | null>(null);

  // лҲ„м Ғ Score лҚ°мқҙн„° мғҒнғң м¶”к°Җ
  const [accumulatedScores, setAccumulatedScores] = useState<any[]>([]);
  const [accumulatedLoading, setAccumulatedLoading] = useState(false);
  
  // кі к°қмӮ¬ м№ҙл“ңмҡ© лҲ„м Ғ м җмҲҳ мғҒнғң м¶”к°Җ
  const [customerAccumulatedScores, setCustomerAccumulatedScores] = useState<any[]>([]);
  const [customerAccumulatedLoading, setCustomerAccumulatedLoading] = useState(false);

  // вң… CAR мғҒнғң кі„мӮ° н•ЁмҲҳ (лӘЁл“  useState лӢӨмқҢ, useMemo мқҙм „м—җ н•ң лІҲл§Ң м •мқҳ)
  const calculateCarStatus = (car: any) => {
    const today = new Date();
    const todayStr = today.toISOString().slice(0, 10);
    
    try {
      // ONE_TIME мқҙлІӨнҠёлҠ” н•ӯмғҒ CLOSED
      if (car.eventType === "ONE_TIME") {
        return "CLOSED";
      } 
      
      // CONTINUOUS мқҙлІӨнҠё мІҳлҰ¬
      if (car.eventType === "CONTINUOUS") {
        // мҷ„лЈҢмқјмқҙ мһҲмңјл©ҙ CLOSED (nullмқҙ м•„лӢҲкі  л№Ҳк°’мқҙ м•„лӢҢ кІҪмҡ°)
        if (car.completionDate && car.completionDate !== null && car.completionDate !== '') {
          return "CLOSED";
        }
        
        // кё°н•ңмқј нҷ•мқё
        if (car.dueDate) {
          // Unix timestampлҘј мҲ«мһҗлЎң ліҖнҷҳн•ҳм—¬ Date к°қмІҙ мғқм„ұ
          let dueDate;
          if (typeof car.dueDate === 'string') {
            // л¬ёмһҗм—ҙмқё кІҪмҡ° мҲ«мһҗлЎң ліҖнҷҳ
            const timestamp = parseInt(car.dueDate);
            dueDate = new Date(timestamp);
          } else {
            // мҲ«мһҗмқё кІҪмҡ° м§Ғм ‘ мӮ¬мҡ©
            dueDate = new Date(car.dueDate);
          }
          
          const dueDateStr = dueDate.toISOString().slice(0, 10);
          
          // мҳӨлҠҳліҙлӢӨ кё°н•ңмқјмқҙ мқҙм „мқҙл©ҙ DELAYED
          if (dueDateStr < todayStr) {
            return "DELAYED";
          }
        }
        
        // мҷ„лЈҢлҗҳм§Җ м•Ҡкі  кё°н•ңлҸ„ м§ҖлӮҳм§Җ м•ҠмқҖ кІҪмҡ° IN_PROGRESS
        return "IN_PROGRESS";
      }
      
      // к·ё мҷёмқҳ кІҪмҡ° IN_PROGRESS
      return "IN_PROGRESS";
    } catch (err) {
      console.error('мғҒнғң кі„мӮ° мҳӨлҘҳ:', err, car);
      return "IN_PROGRESS";
    }
  };

  // вң… Status кё°л°ҳ м§‘кі„лҘј мң„н•ң useMemo (KPIмҷҖ лҸҷмқјн•ң лҚ°мқҙн„° мҶҢмҠӨ мӮ¬мҡ©)
      const statusCounts = useMemo(() => {
      // кё°ліё лҚ°мқҙн„°к°Җ м—Ҷмңјл©ҙ л№Ҳ кө¬мЎ° мӮ¬мҡ©  
      const currentData = data || { kpi: { inProgress: 0, delayed: 0, closed: 0 } };
    
    // KPI лҚ°мқҙн„°мҷҖ лҸҷмқјн•ң мҶҢмҠӨлҘј мӮ¬мҡ©н•ҳм—¬ лҚ°мқҙн„° м •н•©м„ұ ліҙмһҘ
    return {
      IN_PROGRESS: currentData.kpi.inProgress || 0,
      DELAYED: currentData.kpi.delayed || 0,
      CLOSED: currentData.kpi.closed || 0
      };
    }, [data]);

  // мӮ¬мҡ©мһҗ м •ліҙ лЎңл“ң
  useEffect(() => {
    setUser(getCurrentUser() as RoleUser | null);
  }, []);

  // лҢҖмӢңліҙл“ң лҚ°мқҙн„° лЎңл“ң
  useEffect(() => {
    const loadDashboardData = async () => {
      setLoading(true);
      
      // кё°ліё мғҒнғң лӘ©лЎқ лҜёлҰ¬ м„Өм •
      if (statuses.length === 0) {
        setStatuses(['IN_PROGRESS', 'DELAYED', 'CLOSED']);
      }
      
      // лЎңк·ёмқё мғҒнғң нҷ•мқё
      const token = typeof window !== 'undefined' ? sessionStorage.getItem('token') : null;
      
      if (!token) {
        setError('лЎңк·ёмқёмқҙ н•„мҡ”н•©лӢҲлӢӨ.');
        setLoading(false);
        return;
      }
      
      try {
        // 1. CAR лҚ°мқҙн„° лЎңл“ң (лҢҖмӢңліҙл“ң KPIмҡ©)
        const carsResponse = await apiFetch('/api/car?limit=1000');
        
        // API мқ‘лӢө кө¬мЎ° нҷ•мқё л°Ҹ лҚ°мқҙн„° м¶”м¶ң
        let cars = [];
        if (Array.isArray(carsResponse)) {
          cars = carsResponse;
        } else if (carsResponse && carsResponse.items) {
          cars = carsResponse.items;
        } else if (carsResponse && carsResponse.data) {
          cars = carsResponse.data;
        } else {
          console.warn('мҳҲмғҒн•ҳм§Җ лӘ»н•ң CAR API мқ‘лӢө кө¬мЎ°:', carsResponse);
        }
        


        // 2. мЈјк°„ ліҙкі м„ң лҚ°мқҙн„° лЎңл“ң (м „лһө м ңм–ёмҡ©)
        let weeklyReportData = null;
        try {
          const reportResponse = await apiFetch('/api/report/weekly/latest');
          weeklyReportData = reportResponse;
        } catch (reportError) {
          // мЈјк°„ ліҙкі м„ңлҠ” м„ нғқмӮ¬н•ӯмқҙлҜҖлЎң м—җлҹ¬ л¬ҙмӢң
        }

        // 3. кі к°қ лӢҙлӢ№мһҗ лҚ°мқҙн„° лЎңл“ң (group, department н•„н„°л§Ғмҡ©)
        const customersResponse = await apiFetch('/api/customer');
        
        // кі к°қ лҚ°мқҙн„° м¶”м¶ң
        let customers = [];
        if (Array.isArray(customersResponse)) {
          customers = customersResponse;
        } else if (customersResponse && customersResponse.items) {
          customers = customersResponse.items;
        } else if (customersResponse && customersResponse.data) {
          customers = customersResponse.data;
        } else {
          console.warn('мҳҲмғҒн•ҳм§Җ лӘ»н•ң кі к°қ API мқ‘лӢө кө¬мЎ°:', customersResponse);
        }
        

        
        // кі к°қ к·ёлЈ№ м¶”м¶ң (мӨ‘ліө м ңкұ°)
        const uniqueGroups = Array.from(new Set(customers.map((c: any) => c.group).filter(Boolean))) as string[];
        setCustomerGroups(uniqueGroups);
        
        // л¶Җм„ң м¶”м¶ң (мӨ‘ліө м ңкұ°)
        const uniqueDepartments = Array.from(new Set(customers.map((c: any) => c.department).filter(Boolean))) as string[];
        
        // л¶Җм„ң лҚ°мқҙн„°к°Җ м—Ҷмңјл©ҙ кё°ліё л¶Җм„ң мӮ¬мҡ©
        const finalDepartments = uniqueDepartments.length > 0 
          ? uniqueDepartments 
          : ['Purchasing', 'Engineering', 'Quality', 'Production', 'Developing'];
        
        setDepartments(finalDepartments);

        // 4. лҚ°мқҙн„° к°Җкіө
        const processedData = processDashboardData(cars, customers, weeklyReportData);
        
        setData(processedData);
        setWeeklyReport(weeklyReportData);
        setError(null);
      } catch (err: any) {
        setError(err.message || 'лҚ°мқҙн„° лЎңл“ң мӢӨнҢЁ');
        // м—җлҹ¬ мӢң л№Ҳ лҚ°мқҙн„°лЎң мҙҲкё°нҷ”
        setData(getEmptyDashboardData());
        // м—җлҹ¬ мӢң кё°ліё мғҒнғң лӘ©лЎқ к°•м ң м„Өм •
        setStatuses(['IN_PROGRESS', 'DELAYED', 'CLOSED']);
        setCustomerGroups([]);
        setDepartments(['Purchasing', 'Engineering', 'Quality', 'Production', 'Developing']);
      } finally {
        setLoading(false);
      }
    };

    loadDashboardData();
  }, [filteredFilters]);

  // лҲ„м Ғ Score лҚ°мқҙн„° лЎңл“ң н•ЁмҲҳ
  const loadAccumulatedScores = async () => {
    try {
      setAccumulatedLoading(true);
      
      // нҳ„мһ¬ н•„н„°мқҳ endMonth лҳҗлҠ” нҳ„мһ¬ мӣ” мӮ¬мҡ©
      const now = new Date();
      const targetYear = filters.endMonth ? new Date(filters.endMonth).getFullYear() : now.getFullYear();
      const targetMonth = filters.endMonth ? new Date(filters.endMonth).getMonth() + 1 : now.getMonth() + 1;
      
      const result = await apiFetch(
        `/api/car/accumulated-scores?groupType=${groupTab}&year=${targetYear}&month=${targetMonth}`
      );

      
      if (result.success) {
        setAccumulatedScores(result.data || []);
      } else {
        throw new Error(result.message || 'лҲ„м Ғ м җмҲҳ лҚ°мқҙн„° лЎңл“ң мӢӨнҢЁ');
      }
    } catch (error) {
      console.error('лҲ„м Ғ Score лЎңл“ң мҳӨлҘҳ:', error);
      setAccumulatedScores([]);
    } finally {
      setAccumulatedLoading(false);
    }
  };

  // groupTab ліҖкІҪ мӢң лҲ„м Ғ Score лӢӨмӢң лЎңл“ң
  useEffect(() => {
    if (!loading) {
      loadAccumulatedScores();
    }
  }, [groupTab, filters.endMonth]);

  // кі к°қмӮ¬ м№ҙл“ңмҡ© лҲ„м Ғ Score лҚ°мқҙн„° лЎңл“ң н•ЁмҲҳ
  const loadCustomerAccumulatedScores = async () => {
    try {
      setCustomerAccumulatedLoading(true);
      
      // нҳ„мһ¬ н•„н„°мқҳ endMonth лҳҗлҠ” нҳ„мһ¬ мӣ” мӮ¬мҡ©
      const now = new Date();
      const targetYear = filters.endMonth ? new Date(filters.endMonth).getFullYear() : now.getFullYear();
      const targetMonth = filters.endMonth ? new Date(filters.endMonth).getMonth() + 1 : now.getMonth() + 1;
      
      const result = await apiFetch(
        `/api/car/accumulated-scores?groupType=customer&year=${targetYear}&month=${targetMonth}`
      );
      
      if (result.success) {
        setCustomerAccumulatedScores(result.data || []);
      } else {
        throw new Error(result.message || 'кі к°қмӮ¬ лҲ„м Ғ м җмҲҳ лҚ°мқҙн„° лЎңл“ң мӢӨнҢЁ');
      }
    } catch (error) {
      console.error('кі к°қмӮ¬ лҲ„м Ғ Score лЎңл“ң мҳӨлҘҳ:', error);
      setCustomerAccumulatedScores([]);
    } finally {
      setCustomerAccumulatedLoading(false);
    }
  };

  // лҚ°мқҙн„° лЎңл“ң мҷ„лЈҢ нӣ„ кі к°қмӮ¬ лҲ„м Ғ м җмҲҳ лЎңл“ң
  useEffect(() => {
    if (!loading && data) {
      loadCustomerAccumulatedScores();
    }
  }, [filters.endMonth, data]);

  // рҹ“Ҳ мӣ”лі„ м¶”мқҙ лҚ°мқҙн„° мғҒнғң
  const [monthlyTrendData, setMonthlyTrendData] = useState<any[]>([]);
  const [monthlyTrendLoading, setMonthlyTrendLoading] = useState(false);

  // л””лІ„к№…мҡ©: мғҒнғң ліҖнҷ” лЎңк·ё
  useEffect(() => {
    console.log('мӣ”лі„ м¶”мқҙ мғҒнғң ліҖнҷ”:', {
      dataLength: monthlyTrendData.length,
      loading: monthlyTrendLoading,
      data: monthlyTrendData
    });
  }, [monthlyTrendData, monthlyTrendLoading]);

  // рҹ”Ҙ к·ёлЈ№лі„ лҲ„м Ғ Score м§‘кі„
  const calculateGroupAccumulatedScores = (cars: any[], groupType: string) => {
    const now = new Date();
    const targetYear = filters.endMonth ? new Date(filters.endMonth).getFullYear() : now.getFullYear();
    const targetMonth = filters.endMonth ? new Date(filters.endMonth).getMonth() + 1 : now.getMonth() + 1;
    
    const groupStats = new Map();

    cars.forEach(car => {
      const accumulatedScore = calculateAccumulatedScore(car, targetYear, targetMonth);
      
      // лҲ„м Ғ м җмҲҳк°Җ мһҲкұ°лӮҳ кё°ліё м җмҲҳк°Җ мһҲмңјл©ҙ нҸ¬н•Ё
      const hasAnyScore = accumulatedScore > 0 || (car.calculatedScore || car.score || 0) > 0;
      if (!hasAnyScore) return; // м–ҙл–Ө м җмҲҳлҸ„ м—Ҷмңјл©ҙ мҠӨнӮө

      let groupKeys: string[] = [];

      if (groupType === 'company') {
        // лІ•мқёлі„
        groupKeys = [car.corporation || 'Unknown'];
      } else if (groupType === 'customer') {
        // кі к°қмӮ¬лі„ (CustomerContactмқҳ group кё°мӨҖ)
        const customerContacts = car.carCustomerContacts || car.customerContacts || [];
        if (customerContacts.length > 0) {
          customerContacts.forEach((cc: any) => {
            const group = cc.CustomerContact?.group || cc.customerContact?.group || cc.group;
            if (group) groupKeys.push(group);
          });
        }
        if (groupKeys.length === 0) groupKeys = ['Unknown'];
      } else if (groupType === 'manager') {
        // лӢҙлӢ№мһҗлі„ (CustomerContactмқҳ name кё°мӨҖ)
        const customerContacts = car.carCustomerContacts || car.customerContacts || [];
        if (customerContacts.length > 0) {
          customerContacts.forEach((cc: any) => {
            let managerName = null;
            
            if (cc.CustomerContact && cc.CustomerContact.name) {
              managerName = cc.CustomerContact.name;
            } else if (cc.customerContact && cc.customerContact.name) {
              managerName = cc.customerContact.name;
            } else if (cc.name) {
              managerName = cc.name;
            }
            
            if (managerName) {
              groupKeys.push(managerName);
            }
          });
        }
      }

      groupKeys.forEach(groupKey => {
        if (!groupStats.has(groupKey)) {
          groupStats.set(groupKey, {
            name: groupKey,
            score: 0,
            accumulatedScore: 0,
            sentimentScore: 0,
            total: 0,
            eventCount: 0
          });
        }
        
        const group = groupStats.get(groupKey);
        group.accumulatedScore += accumulatedScore;
        group.eventCount += 1;
        group.total += 1;
        // кё°мЎҙ м җмҲҳлҸ„ мң м§Җ (л№„көҗмҡ©)
        group.score += car.calculatedScore || car.score || 0;
        group.sentimentScore += (car.internalScore || 0) + (car.customerScore || 0);
      });
    });

    return Array.from(groupStats.values())
      .sort((a, b) => b.accumulatedScore - a.accumulatedScore);
  };

  // рҹ”Ҙ л°ұм—”л“ң лҲ„м Ғ м җмҲҳ API кІ°кіјлҘј мҡ°м„  мӮ¬мҡ©, м—Ҷмңјл©ҙ кё°мЎҙ лЎңм§Ғ мӮ¬мҡ©
  const enhancedGroupData = !accumulatedLoading && accumulatedScores.length > 0 
    ? accumulatedScores
    : data.carList && data.carList.length > 0 
      ? calculateGroupAccumulatedScores(data.carList, groupTab)
      : (
          groupTab === 'company' ? data.corporations :
          groupTab === 'customer' ? data.customers :
          groupTab === 'manager' ? data.managers :
          data.customerContacts
        );
    
  const sortedGroup = [...enhancedGroupData]
    .sort((a, b) => {
      const scoreA = a.accumulatedScore !== undefined ? a.accumulatedScore : a.score;
      const scoreB = b.accumulatedScore !== undefined ? b.accumulatedScore : b.score;
      return scoreB - scoreA || b.total - a.total || a.name.localeCompare(b.name, 'ko-KR');
    })
    .filter(item => {
      // м җмҲҳк°Җ мһҲлҠ” н•ӯлӘ©л§Ң н•„н„°л§Ғ (0лҸ„ нҸ¬н•Ё)
      const score = item.accumulatedScore !== undefined ? item.accumulatedScore : item.score;
      return score !== undefined && score !== null;
    });

  // рҹ”Ҙ к°„лӢЁн•ң Line Chart мӣ”лі„ м¶”мқҙ лҚ°мқҙн„° (м„ұлҠҘ мөңм Ғнҷ”)
  const lineChartData = useMemo(() => {
    if (!sortedGroup || sortedGroup.length === 0) {
      return [];
    }
    
    // к°ҖмһҘ лҶ’мқҖ м җмҲҳ к·ёлЈ№мқҳ к°„лӢЁн•ң мӣ”лі„ м¶”мқҙ (лҚ”лҜё лҚ°мқҙн„°лЎң м„ұлҠҘ мөңм Ғнҷ”)
    const topGroup = sortedGroup[0];
    const months = ['7мӣ”', '8мӣ”', '9мӣ”', '10мӣ”', '11мӣ”', '12мӣ”'];
    const baseScore = topGroup.accumulatedScore || topGroup.score || 100;
    const baseSentiment = topGroup.sentimentScore || 50;
    
    return months.map((month, index) => ({
      month,
      score: Math.round((baseScore * (0.8 + index * 0.04)) * 100) / 100,
      sentimentScore: Math.round((baseSentiment * (0.9 + index * 0.02)) * 100) / 100,
      groupName: topGroup.name
    }));
  }, [sortedGroup]);

  // рҹ”Ҙ мӣ”лі„ м¶”мқҙ мғҒнғң м—…лҚ°мқҙнҠё (к°„мҶҢнҷ”)
  useEffect(() => {
    setMonthlyTrendData(lineChartData);
    setMonthlyTrendLoading(false);
  }, [lineChartData]);

  // мғҒнғңлі„ PieChart лҚ°мқҙн„°
  const pieData = {
    labels: Object.keys(statusCounts).map(status => {
      const count = statusCounts[status as keyof typeof statusCounts];
      const percentage = getPercentage(count);
      return `${status} ${percentage}%`;
    }),
    datasets: [{
      data: Object.values(statusCounts),
      backgroundColor: [
        '#22d3ee', // IN_PROGRESS - мІӯлЎқмғү
        '#f59e0b', // DELAYED - мЈјнҷ©мғү
        '#10b981', // CLOSED - л…№мғү
      ],
      borderWidth: 0,
    }],
  };

  const pieOptions = {
    plugins: { 
      legend: { 
        labels: { 
          color: '#fff', 
          font: { size: 12 },
          usePointStyle: true,
          pointStyle: 'rect',
          padding: 15,
          boxWidth: 12,
          boxHeight: 12,
          maxWidth: 200,
        },
        position: 'right' as const,
        align: 'center' as const,
        maxWidth: 150,
      },
      tooltip: {
        backgroundColor: 'rgba(0, 0, 0, 0.8)',
        titleColor: '#fff',
        bodyColor: '#fff',
        borderColor: '#333',
        borderWidth: 1,
        callbacks: {
          label: function(context: any) {
            const status = Object.keys(statusCounts)[context.dataIndex];
            const count = context.parsed;
            const percentage = getPercentage(count);
            return `${status}: ${count}кұҙ (${percentage}%)`;
          }
        }
      }
    },
    cutout: '0%',
    responsive: true,
    maintainAspectRatio: false,
    layout: {
      padding: 0  // вң… лӘЁл“  м—¬л°ұ м ңкұ°
    }
  };

  const barData = chartTab === 'score' ? {
    labels: sortedGroup.map(g => g.name),
    datasets: [{
      label: 'лҲ„м Ғ Score н•©кі„',
      data: sortedGroup.map(g => g.accumulatedScore !== undefined ? g.accumulatedScore : g.score),
      backgroundColor: '#60a5fa',
      borderRadius: 6,
    }],
  } : {
    labels: sortedGroup.map(g => g.name),  
    datasets: [{
      label: 'SentimentScore н•©кі„',
      data: sortedGroup.map(g => g.sentimentScore),
      backgroundColor: '#a78bfa',
      borderRadius: 6,
    }],
  };

  const barOptions = {
    plugins: { 
      legend: { display: false },
      tooltip: {
        backgroundColor: 'rgba(0, 0, 0, 0.8)',
        titleColor: '#fff',
        bodyColor: '#fff',
        borderColor: '#333',
        borderWidth: 1,
        callbacks: {
          label: function(context: any) {
            const value = context.parsed.y;
            return `${context.dataset.label}: ${value.toFixed(1)}`;
          }
        }
      }
    },
    scales: {
      x: { 
        ticks: { 
          color: '#fff',
          maxRotation: 45,
          minRotation: 0,
          font: { size: 11 }
        }, 
        grid: { color: '#333' }
      },
      y: { 
        ticks: { 
          color: '#fff',
          font: { size: 11 }
        }, 
        grid: { color: '#333' }
      }
    },
    responsive: true,
    maintainAspectRatio: false,
    interaction: {
      intersect: false,
      mode: 'index' as const
    },
    elements: {
      bar: {
        borderWidth: 0
      }
    },
    layout: {
      padding: {
        top: 10,
        bottom: 10,
        left: 5,
        right: 5
      }
    }
  };

  // лқјмқё м°ЁнҠё лҚ°мқҙн„° (кі„мӮ°лҗң мӣ”лі„ м¶”мқҙ лҚ°мқҙн„° мӮ¬мҡ©)
  const lineData = {
    labels: monthlyTrendData.map(item => item.month || `${item.monthKey}мӣ”`),
    datasets: [{
      label: chartTab === 'score' ? 'лҲ„м Ғ Score м¶”мқҙ' : 'Sentiment м¶”мқҙ',
      data: chartTab === 'score' 
        ? monthlyTrendData.map(item => Number(item.score) || 0)
        : monthlyTrendData.map(item => Number(item.sentimentScore) || 0),
      borderColor: chartTab === 'score' ? '#60a5fa' : '#a78bfa',
      backgroundColor: chartTab === 'score' ? 'rgba(96, 165, 250, 0.1)' : 'rgba(167, 139, 250, 0.1)',
      tension: 0.4,
      pointBackgroundColor: '#fff',
      pointBorderColor: chartTab === 'score' ? '#60a5fa' : '#a78bfa',
      pointRadius: 4,
      pointHoverRadius: 6,
      fill: true,
    }],
  };

  const lineOptions = {
    plugins: { 
      legend: { display: false },
      tooltip: {
        backgroundColor: 'rgba(0, 0, 0, 0.8)',
        titleColor: '#fff',
        bodyColor: '#fff',
        borderColor: '#333',
        borderWidth: 1,
        callbacks: {
          label: function(context: any) {
            const value = context.parsed.y;
            const label = chartTab === 'score' ? 'лҲ„м Ғ Score' : 'Sentiment';
            return `${label}: ${value.toFixed(1)}`;
          }
        }
      }
    },
    scales: {
      x: { 
        ticks: { 
          color: '#fff',
          font: { size: 11 }
        }, 
        grid: { color: '#333' }
      },
      y: { 
        ticks: { 
          color: '#fff',
          font: { size: 11 }
        }, 
        grid: { color: '#333' },
        beginAtZero: true
      }
    },
    responsive: true,
    maintainAspectRatio: false,
    interaction: {
      intersect: false,
      mode: 'index' as const
    },
    elements: {
      line: {
        borderWidth: 2
      },
      point: {
        hoverBorderWidth: 3
      }
    }
  };

  // лҚ°мқҙн„° к°Җкіө н•ЁмҲҳ
  const processDashboardData = (cars: any[], customers: any[], weeklyReport: any) => {
    // 1. лӘЁл“  CAR лҚ°мқҙн„°м—җ лҸҷм Ғ мғҒнғң м¶”к°Җ
    const carsWithStatus = cars.map((car, index) => {
      try {
        const status = calculateCarStatus(car);
        return {
          ...car,
          status
        };
      } catch (error) {
        console.error(`CAR ${index} мІҳлҰ¬ м—җлҹ¬:`, error, car);
        return {
          ...car,
          status: 'IN_PROGRESS'
        };
      }
    });

    // 2. кі мң  мғҒнғң лӘ©лЎқ м¶”м¶ң
    const uniqueStatuses = Array.from(new Set(carsWithStatus.map(car => car.status))) as string[];
    
    // мғҒнғң лҚ°мқҙн„°к°Җ м—Ҷмңјл©ҙ кё°ліё мғҒнғң мӮ¬мҡ©
    const finalStatuses = uniqueStatuses.length > 0 
      ? uniqueStatuses 
      : ['IN_PROGRESS', 'DELAYED', 'CLOSED'];
    
    setStatuses(finalStatuses);

    // KPI кі„мӮ°
    const now = new Date();
    const threeDaysLater = new Date(now.getTime() + 3 * 24 * 60 * 60 * 1000);
    
    const kpi = {
      total: carsWithStatus.length,
      inProgress: carsWithStatus.filter(car => car.status === 'IN_PROGRESS').length,
      delayed: carsWithStatus.filter(car => car.status === 'DELAYED').length, 
      closed: carsWithStatus.filter(car => car.status === 'CLOSED').length,
      dueSoon: carsWithStatus.filter(car => {
        if (!car.dueDate) return false;
        
        // Unix timestamp мІҳлҰ¬
        let dueDate;
        if (typeof car.dueDate === 'string') {
          dueDate = new Date(parseInt(car.dueDate));
        } else {
          dueDate = new Date(car.dueDate);
        }
        
        if (isNaN(dueDate.getTime())) return false; // мң нҡЁн•ҳм§Җ м•ҠмқҖ лӮ м§ң м ңмҷё
        return dueDate <= threeDaysLater && dueDate >= now;
      }).length
    };

    // лІ•мқёлі„ м§‘кі„
    const corporationStats: { [key: string]: any } = {};
    carsWithStatus.forEach(car => {
      const corp = car.corporation || 'Unknown';
      if (!corporationStats[corp]) {
        corporationStats[corp] = { name: corp, total: 0, score: 0, sentimentScore: 0, eventCount: 0 };
      }
      corporationStats[corp].total++;
      corporationStats[corp].eventCount++;
      corporationStats[corp].score += car.calculatedScore || 0;
      corporationStats[corp].sentimentScore += (car.internalScore || 0) + (car.customerScore || 0);
    });
    const corporations = Object.values(corporationStats);

    // кі к°қмӮ¬лі„ м§‘кі„ (carCustomerContactsлҘј нҶөн•ң group кё°мӨҖ)
    const customerStats: { [key: string]: any } = {};
    
    carsWithStatus.forEach(car => {
      let customerGroup = 'Unknown';
      
      // CARмқҳ customerContacts лҳҗлҠ” carCustomerContacts л°°м—ҙм—җм„ң кі к°қмӮ¬ м •ліҙ м¶”м¶ң
      const customerContacts = car.customerContacts || car.carCustomerContacts || [];
      
      if (Array.isArray(customerContacts) && customerContacts.length > 0) {
        // мІ« лІҲм§ё customerContactмқҳ м •ліҙ мӮ¬мҡ©
        const firstContact = customerContacts[0];
        if (firstContact && firstContact.customerContact) {
          // customerContact к°қмІҙм—җм„ң group м¶”м¶ң
          customerGroup = firstContact.customerContact.group || 'Unknown';
        } else if (firstContact && firstContact.group) {
          // м§Ғм ‘ group н•„л“ңк°Җ мһҲлҠ” кІҪмҡ°
          customerGroup = firstContact.group;
        }
      }
      
      if (!customerStats[customerGroup]) {
        customerStats[customerGroup] = { 
          name: customerGroup, 
          total: 0, 
          score: 0, 
          sentimentScore: 0, 
          eventCount: 0 
        };
      }
      customerStats[customerGroup].total++;
      customerStats[customerGroup].eventCount++;
      customerStats[customerGroup].score += car.calculatedScore || 0;
      customerStats[customerGroup].sentimentScore += (car.internalScore || 0) + (car.customerScore || 0);
    });
    
    const customersData = Object.values(customerStats);

    // лӢҙлӢ№мһҗлі„ м§‘кі„ (CustomerContactмқҳ name кё°мӨҖ)
    const managerStats: { [key: string]: any } = {};
    carsWithStatus.forEach(car => {
      const customerContacts = car.customerContacts || car.carCustomerContacts || [];
      
      if (Array.isArray(customerContacts) && customerContacts.length > 0) {
        customerContacts.forEach((contact: any) => {
          let managerName = null;
          
          if (contact && contact.customerContact && contact.customerContact.name) {
            // customerContact к°қмІҙм—җм„ң name м¶”м¶ң
            managerName = contact.customerContact.name;
          } else if (contact && contact.name) {
            // м§Ғм ‘ name н•„л“ңк°Җ мһҲлҠ” кІҪмҡ°
            managerName = contact.name;
          }
          
          if (managerName) {
            if (!managerStats[managerName]) {
              managerStats[managerName] = { name: managerName, total: 0, score: 0, sentimentScore: 0, eventCount: 0 };
            }
            managerStats[managerName].total++;
            managerStats[managerName].eventCount++;
            managerStats[managerName].score += car.calculatedScore || 0;
            managerStats[managerName].sentimentScore += (car.internalScore || 0) + (car.customerScore || 0);
          }
        });
      }
    });
    const managersData = Object.values(managerStats);

    // Worst Score/Delay кі„мӮ°
    const worstScore = [...carsWithStatus]
      .filter(car => car.calculatedScore !== undefined && car.calculatedScore !== null)
      .sort((a, b) => a.calculatedScore - b.calculatedScore)
      .slice(0, 5)
      .map(car => ({
        date: car.issueDate,
        customer: car.customer || 'Unknown',
        dept: car.customerDepartment || 'Unknown',
        manager: car.internalContact || 'Unknown',
        owner: car.creator?.name || 'Unknown',
        score: car.calculatedScore
      }));

    const worstDelay = carsWithStatus
      .filter(car => car.dueDate && car.status !== 'CLOSED')
      .map(car => {
        // Unix timestamp мІҳлҰ¬
        let due, issue;
        
        if (typeof car.dueDate === 'string') {
          due = new Date(parseInt(car.dueDate));
        } else {
          due = new Date(car.dueDate);
        }
        
        if (typeof car.issueDate === 'string') {
          issue = new Date(parseInt(car.issueDate));
        } else {
          issue = new Date(car.issueDate);
        }
        
        // лӮ м§ң мң нҡЁм„ұ кІҖмӮ¬
        if (isNaN(due.getTime()) || isNaN(issue.getTime())) {
          return null;
        }
        
        const delay = Math.floor((now.getTime() - due.getTime()) / (1000 * 60 * 60 * 24));
        return {
          ...car,
          delay
        };
      })
      .filter(car => car !== null && car.delay > 0)
      .sort((a, b) => b.delay - a.delay)
      .slice(0, 5)
      .map(car => ({
        date: car.issueDate,
        customer: car.customer || 'Unknown',
        dept: car.customerDepartment || 'Unknown', 
        manager: car.internalContact || 'Unknown',
        owner: car.creator?.name || 'Unknown',
        due: car.dueDate,
        delay: car.delay
      }));

    return {
      kpi,
      corporations,
      customers: customersData,
      customerContacts: customers.slice(0, 6).map(c => ({ 
        name: c.name, 
        customer: c.company || c.group,
        total: Math.floor(Math.random() * 20), 
        score: Math.floor(Math.random() * 50), 
        sentimentScore: Math.floor(Math.random() * 60) 
      })),
      managers: managersData,
      carList: carsWithStatus.slice(0, 20),
      worstScore,
      worstDelay
    };
  };

  // н•„н„° н•ёл“Өлҹ¬
  const handleFilterChange = (key: string, value: string) => {
    setFilters(prev => ({ ...prev, [key]: value }));
  };

  const handleCustomerGroupsChange = (selectedGroups: string[]) => {
    setFilters(prev => ({ ...prev, customerGroups: selectedGroups }));
  };

  const handleDepartmentChange = (selectedDepartment: string) => {
    setFilters(prev => ({ ...prev, dept: selectedDepartment }));
  };

  const handleStatusChange = (selectedStatus: string) => {
    setFilters(prev => ({ ...prev, status: selectedStatus }));
  };

  const handleSearch = () => {
    setFilteredFilters(filters);
  };

  const handleReset = () => {
    const reset = {
      corp: 'м „мІҙ',
      customerGroups: [] as string[],
      dept: 'м „мІҙ', 
      status: 'м „мІҙ',
      startMonth: '',
      endMonth: '',
      manager: ''
    };
    setFilters(reset);
    setFilteredFilters(reset);
  };

  // кі к°қмӮ¬ м№ҙл“ң нҒҙлҰӯ н•ёл“Өлҹ¬
  const handleCompanyCardClick = async (company: any) => {
    if (!weeklyReport?.data?.[company.name]) {
      setToast('н•ҙлӢ№ кі к°қмӮ¬мқҳ мЈјк°„ ліҙкі м„ңк°Җ м—ҶмҠөлӢҲлӢӨ.');
      setTimeout(() => setToast(null), 1500);
      return;
    }

    setModalLoading(true);
    setModalOpen(true);
    setModalError(null);
    
    try {
      const reportData = weeklyReport.data[company.name];
      setModalData({ 
        customer: company.name,
        ...reportData,
        updatedAt: weeklyReport.updatedAt 
      });
    } catch (err: any) {
      setModalError(err.message || 'лҚ°мқҙн„° лЎңл“ң мӢӨнҢЁ');
    } finally {
      setModalLoading(false);
    }
  };

  const handleCopy = (text: string) => {
    navigator.clipboard.writeText(text);
    setToast('ліөмӮ¬лҗҳм—ҲмҠөлӢҲлӢӨ');
    setTimeout(() => setToast(null), 1500);
  };

  // ESC нӮӨ н•ёл“Өлҹ¬
  useEffect(() => {
    const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') setModalOpen(false); };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, []);

  // рҹ”Ҙ лҲ„м Ғ кё°к°„ л°ҳмҳҒ Score кі„мӮ° н•ЁмҲҳ
  const calculateAccumulatedScore = (car: any, targetYear: number, targetMonth: number) => {
    const score = car.calculatedScore || car.score || 0;
    const eventType = car.eventType;
    
    if (!car.issueDate && !car.completionDate) return 0;
    
    let startDate: Date;
    let duration: number; // к°ңмӣ” мҲҳ

    if (eventType === 'ONE_TIME') {
      // ONE_TIME: issueDateлЎңл¶Җн„° 6к°ңмӣ”к°„
      startDate = new Date(Number(car.issueDate));
      duration = 6;
    } else if (eventType === 'CONTINUOUS') {
      // CONTINUOUS: completionDateлЎңл¶Җн„° 12к°ңмӣ”к°„
      if (!car.completionDate) return 0;
      startDate = new Date(Number(car.completionDate));
      duration = 12;
    } else {
      return 0;
    }

    // мң нҡЁн•ҳм§Җ м•ҠмқҖ лӮ м§ң мІҙнҒ¬
    if (isNaN(startDate.getTime())) return 0;

    // targetDateк°Җ startDate ~ startDate+duration лІ”мң„м—җ мһҲлҠ”м§Җ нҷ•мқё
    const targetDate = new Date(targetYear, targetMonth - 1, 1);
    const endDate = new Date(startDate.getFullYear(), startDate.getMonth() + duration, 0);
    
    if (targetDate >= startDate && targetDate <= endDate) {
      return score;
    }
    return 0;
  };

  // нҚјм„јнҠё кі„мӮ° н•ЁмҲҳ
  const getPercentage = (count: number) => {
    if (totalCars === 0) return '0.0';
    return ((count / totalCars) * 100).toFixed(1);
  };

  // мғҒлӢЁ кі к°қмӮ¬ м№ҙл“ң лҚ°мқҙн„° (мғҒмң„ 6к°ң, мҡ°м„ мҲңмң„: eventмҲҳ вҶ’ лҲ„м Ғм җмҲҳ вҶ’ м•ҢнҢҢлІімҲң)
  const customerCards = (() => {
    // 1. лҲ„м Ғ м җмҲҳ лҚ°мқҙн„°к°Җ мһҲмңјл©ҙ мҡ°м„  мӮ¬мҡ©
    if (!customerAccumulatedLoading && customerAccumulatedScores.length > 0) {
      return customerAccumulatedScores
        .sort((a, b) => b.eventCount - a.eventCount || b.accumulatedScore - a.accumulatedScore || a.name.localeCompare(b.name, 'ko-KR'))
        .slice(0, 6)
        .map(item => ({
          ...item,
          total: item.eventCount || 0,
          score: item.accumulatedScore || 0
        }));
    }
    
    // 2. кё°ліё лҚ°мқҙн„° мӮ¬мҡ© (кё°мЎҙ лЎңм§Ғ)
    return [...data.customers]
      .sort((a, b) => b.total - a.total || b.score - a.score || a.name.localeCompare(b.name, 'ko-KR'))
      .slice(0, 6);
  })();

  // мЈјк°„ ліҙкі м„ңк°Җ мһҲлҠ” кі к°қмӮ¬ лӘ©лЎқ
  const reportCustomers = weeklyReport?.data ? Object.keys(weeklyReport.data) : [];

  // мғҒнғңлі„ мҙқн•© кі„мӮ°
  const totalCars = Object.values(statusCounts).reduce((sum: number, count: number) => sum + count, 0);

  // лЎңл”©/м—җлҹ¬ мғҒнғң
  if (!user) return <div className="p-8 text-center">лЎңл”© мӨ‘...</div>;
  if (loading) return <div className="min-h-screen bg-[#181A20] text-white p-8 text-center">лҢҖмӢңліҙл“ң лЎңл”© мӨ‘...</div>;
  if (error && !data) return <div className="min-h-screen bg-[#181A20] text-white p-8 text-center text-red-500">м—җлҹ¬: {error}</div>;

  return (
    <div className="min-h-screen bg-[#181A20] text-white p-4 md:p-8">
      {/* нҶ мҠӨнҠё */}
      {toast && (
        <div className="fixed top-4 right-4 bg-green-600 text-white px-4 py-2 rounded shadow-lg z-50">
          {toast}
        </div>
      )}

      {/* м „лһө м ңм–ё лӘЁлӢ¬ */}
      <StrategyModal 
        open={modalOpen}
        onClose={() => setModalOpen(false)}
        data={modalData}
        loading={modalLoading}
        error={modalError}
        onCopy={handleCopy}
      />

      {/* н•„н„° мҳҒм—ӯ */}
      <div className="bg-[#23242B] border border-[#333] rounded-lg px-3 py-2 mb-4 flex flex-row items-center gap-1">
        <div className="flex flex-col items-start min-w-[120px]">
          <span className="text-xs text-gray-400 mb-0.5">нҡҢмӮ¬</span>
          <select className="bg-[#181A20] border border-[#333] rounded h-10 px-3 text-sm w-full" value={filters.corp} onChange={e => handleFilterChange('corp', e.target.value)}>
            <option>м „мІҙ</option>
            {data.corporations.map((corp: any) => (
              <option key={corp.name} value={corp.name}>{corp.name}</option>
            ))}
          </select>
        </div>
        
        {/* кі к°қмӮ¬ к·ёлЈ№ ліөмҲҳ м„ нғқ л“ңлЎӯлӢӨмҡҙ */}
        <div className="min-w-[150px]">
          <MultiSelectDropdown
            label="кі к°қмӮ¬"
            options={customerGroups}
            selectedValues={filters.customerGroups}
            onSelectionChange={handleCustomerGroupsChange}
            placeholder="м „мІҙ"
          />
        </div>
        
        {/* л¶Җм„ң лӢЁмқј м„ нғқ л“ңлЎӯлӢӨмҡҙ */}
        <div className="min-w-[150px]">
          <SingleSelectDropdown
            label="л¶Җм„ң"
            options={departments}
            selectedValue={filters.dept}
            onSelectionChange={handleDepartmentChange}
            placeholder="м „мІҙ"
          />
        </div>
        {/* мғҒнғң лӢЁмқј м„ нғқ л“ңлЎӯлӢӨмҡҙ */}
        <div className="min-w-[150px]">
          <SingleSelectDropdown
            label={`мғҒнғң (${statuses.length}к°ң)`}
            options={statuses}
            selectedValue={filters.status}
            onSelectionChange={handleStatusChange}
            placeholder="м „мІҙ"
          />
        </div>
        <div className="flex flex-col items-start min-w-[120px]">
          <span className="text-xs text-gray-400 mb-0.5">мӢңмһ‘мӣ”</span>
          <input type="month" className="bg-[#181A20] border border-[#333] rounded h-10 px-3 text-sm w-full [&::-webkit-calendar-picker-indicator]:invert" value={filters.startMonth} onChange={e => handleFilterChange('startMonth', e.target.value)} />
        </div>
        <div className="flex flex-col items-start min-w-[120px]">
          <span className="text-xs text-gray-400 mb-0.5">мў…лЈҢмӣ”</span>
          <input type="month" className="bg-[#181A20] border border-[#333] rounded h-10 px-3 text-sm w-full [&::-webkit-calendar-picker-indicator]:invert" value={filters.endMonth} onChange={e => handleFilterChange('endMonth', e.target.value)} />
        </div>
        <div className="flex flex-col items-start min-w-[140px] max-w-[180px] flex-1">
          <span className="text-xs text-gray-400 mb-0.5">лӢҙлӢ№мһҗ кІҖмғү</span>
          <input
            placeholder="лӢҙлӢ№мһҗлӘ…(мүјн‘ңлЎң ліөмҲҳ мһ…л Ҙ)"
            className="bg-[#181A20] border border-[#333] rounded h-10 px-3 text-sm w-full"
            value={filters.manager}
            onChange={e => handleFilterChange('manager', e.target.value)}
            onKeyDown={e => { if (e.key === 'Enter') handleSearch(); }}
          />
        </div>
        <button className="bg-[#181A20] border border-[#333] rounded w-10 h-10 flex items-center justify-center mt-5" onClick={handleSearch}>
          <svg className="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
          </svg>
        </button>
        <button className="ml-1 bg-[#23242B] border border-[#333] rounded w-10 h-10 flex items-center justify-center mt-5 text-xs text-gray-400" onClick={handleReset}>
          мҙҲкё°нҷ”
        </button>
      </div>

      {/* нҳ„нҷ© м№ҙл“ң + кі к°қмӮ¬ м№ҙл“ң */}
      <div className="flex flex-row gap-2 mb-4 w-full items-center">
        {/* нҳ„нҷ© м№ҙл“ң */}
        <div className="flex flex-row bg-[#181A20] border border-[#444] rounded-lg px-15 py-5 gap-6 shadow-sm h-full items-center">
          {[
            { label: 'м „мІҙ CAR', value: data.kpi.total },
            { label: 'IN PROGRESS', value: data.kpi.inProgress },
            { label: 'DELAYED', value: data.kpi.delayed },
            { label: 'CLOSED', value: data.kpi.closed },
            { label: '3мқј мқҙлӮҙ л§Ҳк°җ', value: data.kpi.dueSoon }
          ].map((item, i) => (
            <div key={i} className="flex flex-col items-center min-w-[80px]">
              <div className="text-xs text-gray-300 font-medium mb-0.5">{item.label}</div>
              <div className="text-xl font-bold text-white">{item.value}</div>
            </div>
          ))}
        </div>

        {/* кі к°қмӮ¬ м№ҙл“ң */}
        <div className="flex flex-row gap-2 flex-1">
          {customerCards.map((c, i) => {
            const hasReport = reportCustomers.includes(c.name);
            return (
              <div
                key={i}
                className={`bg-[#181A20] border border-[#444] rounded-lg px-3 py-2 flex-1 min-w-[100px] flex flex-col items-center justify-center shadow-sm relative ${hasReport ? 'cursor-pointer hover:bg-[#23242B]' : ''}`}
                onClick={() => {
                  if (hasReport) handleCompanyCardClick(c);
                }}
              >
                {hasReport && (
                  <span className="absolute left-2 top-2 w-2 h-2 rounded-full bg-blue-500" />
                )}
                <div className="font-bold text-white text-xs mb-0.5 text-center">{c.name}</div>
                <div className="text-xs text-gray-300 mb-0.5 text-center">м§„н–ү: {c.total}</div>
                <div className="text-xs text-gray-300 mb-0.5 text-center">лҜёкІ°: 0</div>
                <div className="text-xs text-blue-300 font-semibold text-center">
                  лҲ„м Ғ Score: {(c.score || 0).toFixed(1)}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      {/* м°ЁнҠё нғӯ */}
      <div className="flex flex-row gap-2 mb-2">
        {/* к·ёлЈ№ нҶ кёҖ */}
        <div className="flex bg-[#23242B] border border-[#333] rounded-lg p-1">
          {[
            { key: 'company', label: 'лІ•мқё' },
            { key: 'customer', label: 'кі к°қмӮ¬' },
            { key: 'manager', label: 'лӢҙлӢ№мһҗ' }
          ].map(tab => (
            <button
              key={tab.key}
              className={`px-3 py-1 text-xs rounded ${groupTab === tab.key ? 'bg-[#181A20] text-white' : 'text-gray-400'}`}
              onClick={() => setGroupTab(tab.key as any)}
            >
              {tab.label}
            </button>
          ))}
        </div>

        {/* м°ЁнҠё нҶ кёҖ */}
        <div className="flex bg-[#23242B] border border-[#333] rounded-lg p-1">
          {[
            { key: 'score', label: 'Score' },
            { key: 'sentiment', label: 'Sentiment' }
          ].map(tab => (
            <button
              key={tab.key}
              className={`px-3 py-1 text-xs rounded ${chartTab === tab.key ? 'bg-[#181A20] text-white' : 'text-gray-400'}`}
              onClick={() => setChartTab(tab.key as any)}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      {/* м°ЁнҠё мҳҒм—ӯ */}
      <div className="flex flex-col md:flex-row gap-4 mb-4">
        {/* мғҒнғңлі„ PieChart */}
        <div className="bg-[#23242B] rounded px-4 py-1 flex flex-col items-center w-full md:w-1/2">
          <div className="text-sm text-gray-400 mb-0 font-medium">мғҒнғңлі„ л¶„нҸ¬</div>
          <div style={{ width: '350px', height: '250px' }}>
            <Doughnut data={pieData} options={pieOptions} />
          </div>
        </div>

        {/* л°” м°ЁнҠё */}
        <div className="bg-[#23242B] rounded p-4 flex flex-col items-center w-full md:w-1/2">
          <div className="text-sm text-gray-400 mb-3 font-medium">
            {groupTab === 'company' ? 'лІ•мқёлі„' : groupTab === 'customer' ? 'кі к°қмӮ¬лі„' : 'лӢҙлӢ№мһҗлі„'} {chartTab === 'score' ? 'Score' : 'Sentiment'} л№„көҗ ({sortedGroup.length}к°ң)
          </div>
          <div className="w-full h-52">
            <Bar data={barData} options={barOptions} />
          </div>
        </div>
      </div>

      {/* лқјмқё м°ЁнҠё */}
      <div className="bg-[#23242B] rounded p-4 mb-4">
        <div className="text-xs text-gray-400 mb-2 flex items-center gap-2">
          {groupTab === 'company' ? 'лІ•мқёлі„' : groupTab === 'customer' ? 'кі к°қмӮ¬лі„' : 'лӢҙлӢ№мһҗлі„'} {chartTab === 'score' ? 'лҲ„м Ғ Score' : 'Sentiment'} мӣ”лі„ м¶”мқҙ
          {monthlyTrendLoading && (
            <span className="text-xs text-blue-400">лЎңл”© мӨ‘...</span>
          )}
          {!monthlyTrendLoading && monthlyTrendData.length === 0 && (
            <span className="text-xs text-orange-400">лҚ°мқҙн„° м—ҶмқҢ</span>
          )}
          {!monthlyTrendLoading && monthlyTrendData.length > 0 && (
            <span className="text-xs text-green-400">({monthlyTrendData.length}к°ңмӣ”)</span>
          )}
        </div>
        <div className="w-full h-32">
          {monthlyTrendData.length > 0 ? (
            <Line data={lineData} options={lineOptions} />
          ) : (
            <div className="w-full h-full flex items-center justify-center text-gray-500 text-sm">
              {monthlyTrendLoading ? 'мӣ”лі„ м¶”мқҙ лҚ°мқҙн„° лЎңл”© мӨ‘...' : 'н‘ңмӢңн•  лҚ°мқҙн„°к°Җ м—ҶмҠөлӢҲлӢӨ'}
            </div>
          )}
        </div>
      </div>

      {/* н…Ңмқҙлё” мҳҒм—ӯ */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        {/* Worst Score Top5 */}
        <div className="bg-[#23242B] rounded p-4">
          <div className="text-xs text-gray-400 mb-2">Score Worst 5</div>
          <div className="overflow-x-auto">
            <table className="w-full text-xs">
              <thead>
                <tr className="border-b border-[#333]">
                  <th className="text-left py-1">мқјмһҗ</th>
                  <th className="text-left py-1">кі к°қмӮ¬</th>
                  <th className="text-left py-1">л¶Җм„ң</th>
                  <th className="text-left py-1">Score</th>
                </tr>
              </thead>
              <tbody>
                {data.worstScore.map((item: any, i: number) => (
                  <tr key={i} className="border-b border-[#333]/50">
                    <td className="py-1">{item.date}</td>
                    <td className="py-1">{item.customer}</td>
                    <td className="py-1">{item.dept}</td>
                    <td className="py-1 text-red-400">{item.score}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* м§Җм—° Worst5 */}
        <div className="bg-[#23242B] rounded p-4">
          <div className="text-xs text-gray-400 mb-2">м§Җм—° Worst 5</div>
          <div className="overflow-x-auto">
            <table className="w-full text-xs">
              <thead>
                <tr className="border-b border-[#333]">
                  <th className="text-left py-1">мқјмһҗ</th>
                  <th className="text-left py-1">кі к°қмӮ¬</th>
                  <th className="text-left py-1">кё°н•ңмқј</th>
                  <th className="text-left py-1">м§Җм—°мқј</th>
                </tr>
              </thead>
              <tbody>
                {data.worstDelay.map((item: any, i: number) => (
                  <tr key={i} className="border-b border-[#333]/50">
                    <td className="py-1">{item.date}</td>
                    <td className="py-1">{item.customer}</td>
                    <td className="py-1">{item.due}</td>
                    <td className="py-1 text-red-400">{item.delay}мқј</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  );
} 