# ── Database ─────────────────────────────────────────────
# docker-compose 기본값과 일치 (로컬 실행용)
DATABASE_URL=postgresql://ccar:ccar@localhost:5432/ccar?schema=public

# DataMart(ERP) 연동 DB — 로컬 데모에서는 미사용 (비워두면 ERP 동기화 비활성)
DM_DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── Mail (n8n 워크플로우 경유) ────────────────────────────
MAIL_SENDER=noreply@ccar.example.com
MAIL_SENDER_NAME=CCAR System

# ── Kafka (통합 이벤트 로깅, 옵션) ─────────────────────────
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_DETAILED_LOGS=false
KAFKA_LOG_GET_REQUESTS=false

# ── n8n 워크플로우 연동 (옵션 — AI 분석/보고서 메일) ─────────
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=change-me
N8N_NOTIFICATION_WEBHOOK_URL=

# ── 알림 스케줄러 (v2.5) ──────────────────────────────────
NOTIFICATION_SCHEDULER_ENABLED=false
NOTIFICATION_DUEDATE_CRON=0 9 * * *
SCHEDULER_TIMEZONE=Asia/Seoul
APP_BASE_URL=http://localhost:4000

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=CCAR System
APP_VERSION=2.5.0
